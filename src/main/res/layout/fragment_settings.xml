<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="24dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Settings" android:textSize="28sp" android:textStyle="bold" />
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/darkModeSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Dark mode" />
    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/biometricSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Biometric login" />
    <Spinner android:id="@+id/currencySpinner" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="12dp" />
    <com.google.android.material.button.MaterialButton android:id="@+id/profileButton" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Profile" />
    <com.google.android.material.button.MaterialButton android:id="@+id/syncButton" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sync backup" />
    <com.google.android.material.button.MaterialButton android:id="@+id/logoutButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Logout" />
</LinearLayout>

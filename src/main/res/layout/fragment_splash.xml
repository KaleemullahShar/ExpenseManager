<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="32dp">
    <TextView android:id="@+id/logo" android:layout_width="92dp" android:layout_height="92dp" android:background="@drawable/bg_logo" android:gravity="center" android:text="$" android:textColor="@color/white" android:textSize="42sp" android:textStyle="bold" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="@string/app_name" android:textSize="30sp" android:textStyle="bold" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tagline" android:textColor="?android:attr/textColorSecondary" />
</LinearLayout>

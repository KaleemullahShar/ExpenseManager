<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">
    <fragment android:id="@+id/splashFragment" android:name="com.spendwise.ui.auth.SplashFragment" android:label="Splash">
        <action android:id="@+id/action_splash_to_onboarding" app:destination="@id/onboardingFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
        <action android:id="@+id/action_splash_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
        <action android:id="@+id/action_splash_to_dashboard" app:destination="@id/dashboardFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/onboardingFragment" android:name="com.spendwise.ui.auth.OnboardingFragment" android:label="Onboarding">
        <action android:id="@+id/action_onboarding_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/onboardingFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/loginFragment" android:name="com.spendwise.ui.auth.LoginFragment" android:label="Login">
        <action android:id="@+id/action_login_to_signup" app:destination="@id/signupFragment" />
        <action android:id="@+id/action_login_to_forgot" app:destination="@id/forgotPasswordFragment" />
        <action android:id="@+id/action_login_to_dashboard" app:destination="@id/dashboardFragment" app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/signupFragment" android:name="com.spendwise.ui.auth.SignupFragment" android:label="Signup" />
    <fragment android:id="@+id/forgotPasswordFragment" android:name="com.spendwise.ui.auth.ForgotPasswordFragment" android:label="Forgot Password" />
    <fragment android:id="@+id/dashboardFragment" android:name="com.spendwise.ui.main.DashboardFragment" android:label="Dashboard">
        <action android:id="@+id/action_dashboard_to_detail" app:destination="@id/expenseDetailFragment" />
    </fragment>
    <fragment android:id="@+id/historyFragment" android:name="com.spendwise.ui.expense.HistoryFragment" android:label="History">
        <action android:id="@+id/action_history_to_detail" app:destination="@id/expenseDetailFragment" />
    </fragment>
    <fragment android:id="@+id/addExpenseFragment" android:name="com.spendwise.ui.expense.AddExpenseFragment" android:label="Add Expense">
        <argument android:name="expenseId" app:argType="long" android:defaultValue="0L" />
    </fragment>
    <fragment android:id="@+id/expenseDetailFragment" android:name="com.spendwise.ui.expense.ExpenseDetailFragment" android:label="Expense Detail">
        <argument android:name="expenseId" app:argType="long" android:defaultValue="0L" />
    </fragment>
    <fragment android:id="@+id/analyticsFragment" android:name="com.spendwise.ui.main.AnalyticsFragment" android:label="Analytics" />
    <fragment android:id="@+id/budgetFragment" android:name="com.spendwise.ui.budget.BudgetFragment" android:label="Budget" />
    <fragment android:id="@+id/settingsFragment" android:name="com.spendwise.ui.settings.SettingsFragment" android:label="Settings">
        <action android:id="@+id/action_settings_to_profile" app:destination="@id/profileFragment" />
        <action android:id="@+id/action_settings_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/dashboardFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/profileFragment" android:name="com.spendwise.ui.profile.ProfileFragment" android:label="Profile" />
</navigation>
